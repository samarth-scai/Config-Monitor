PORT=3001

# --- DB Connection ---
# Run connect-db.sh first, then configure these.
# For IAM auth (recommended for prod):
USE_IAM_AUTH=true
DB_USER=rds_read_user
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
AWS_REGION=ap-south-1

# For password auth (UAT/demo):
# USE_IAM_AUTH=false
# DB_USER=rds_read_user
# DB_PASSWORD=yourpassword

# Channelkart API (for applying fixes without direct DB writes)
CK_API_BASE_URL=http://localhost:8080
CK_API_TOKEN=your-jwt-token-here
